  <Source dwd:design-time-name="21578906-768b-450d-a453-5906e1ba4bdc">
    <DataSourceViewID>Projekt</DataSourceViewID>
  </Source>
  <MdxScripts>
    <MdxScript dwd:design-time-name="5607ac0d-14af-4e2d-92eb-2ad324a47b2e">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[avg_Drzewo]
 AS [Measures].[Charges - Decision Tree Prediction] / [Measures].[Decision Tree Prediction Count], 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Decision Tree Prediction'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[avg_cluster]
 AS [Measures].[Charges - Clusters Prediction] / [Measures].[Clusters Prediction Count], 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Clusters Prediction'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[avg_siec]
 AS [Measures].[Charges - Neural Network Prediction] / [Measures].[Neural Network Prediction Count], 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Neural Network Prediction'  ; 
CREATE MEMBER CURRENTCUBE.[Measures].[avg_prawdziwe]
 AS [Measures].[Charges] / [Measures].[Fact Insurance Count], 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Fact Insurance'  ;  
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Charges]
 AS [Measures].[Charges] / [Measures].[Fact Insurance Count], 
FORMAT_STRING = "Currency", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Avg Age]
 AS [Measures].[Sum Age] / [Measures].[Fact Insurance Count], 
FORMAT_STRING = "Standard", 
VISIBLE = 1;  
CREATE MEMBER CURRENTCUBE.[Measures].[Avg BMI]
 AS [Measures].[Sum BMI] / [Measures].[Fact Insurance Count], 
FORMAT_STRING = "Standard", 
VISIBLE = 1; </Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="83bce41a-64de-47b7-ac45-7e230030203f">
      <ID>KPI</ID>
      <Name>KPI_Sredni_Koszt</Name>
      <AssociatedMeasureGroupID>Fact Insurance</AssociatedMeasureGroupID>
      <Value>[Measures].[Avg Charges]</Value>
